{
  "agents": {
    "test-review": {
      "enabled": true,
      "severityThreshold": "warning"
    },
    "structure-review": {
      "enabled": true,
      "severityThreshold": "warning"
    },
    "naming-review": {
      "enabled": true,
      "severityThreshold": "warning"
    },
    "domain-review": {
      "enabled": true,
      "severityThreshold": "warning"
    },
    "complexity-review": {
      "enabled": true,
      "severityThreshold": "warning",
      "maxComplexity": 10
    },
    "claude-setup-review": {
      "enabled": true,
      "severityThreshold": "warning"
    },
    "token-efficiency-review": {
      "enabled": true,
      "maxClaudeMdLength": 5000,
      "maxFileLength": 500,
      "maxFunctionLength": 50
    },
    "security-review": {
      "enabled": true,
      "severityThreshold": "warning"
    },
    "fp-review": {
      "enabled": true,
      "allowedMutablePrefixes": ["mut", "mutable", "_"],
      "strictMode": true
    }
  },
  "orchestrator": {
    "maxLoopIterations": 5,
    "failOnError": true,
    "parallel": false
  }
}
